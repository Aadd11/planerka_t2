# Имя базы данных PostgreSQL.
POSTGRES_DB=t2_schedule
# Пользователь PostgreSQL.
POSTGRES_USER=postgres
# Пароль пользователя PostgreSQL.
POSTGRES_PASSWORD=postgres

# Полный URL подключения backend к базе данных.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/t2_schedule
# Секретный ключ для подписи JWT. В реальном окружении замените на длинное случайное значение.
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# Алгоритм подписи JWT.
JWT_ALGORITHM=HS256
# Время жизни access token в минутах.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Разрешённые источники для CORS через запятую.
CORS_ORIGINS=http://localhost:8000,http://localhost:5173
# Каталог для временных экспортов.
EXPORT_DIR=/tmp
# Текущее окружение приложения: development, test или production.
APP_ENV=development
