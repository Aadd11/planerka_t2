# Полный URL подключения backend к базе данных в формате
# postgresql+psycopg://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БАЗЫ
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/t2_schedule

# Секретный ключ для подписи JWT. В реальном окружении замените на длинное случайное значение.
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# Алгоритм подписи JWT.
JWT_ALGORITHM=HS256
# Время жизни access token в минутах.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Разрешённые источники для CORS через запятую.
CORS_ORIGINS=http://localhost:8000,http://localhost:5173
# Текущее окружение приложения: development, test или production.
APP_ENV=development
# Уровень логирования приложения.
LOG_LEVEL=info
# Количество worker-процессов API в production-конфигурации.
WEB_CONCURRENCY=2
# Базовый размер пула соединений с БД.
DB_POOL_SIZE=5
# Максимальное количество дополнительных соединений сверх пула.
DB_MAX_OVERFLOW=10
# Таймаут ожидания свободного соединения из пула в секундах.
DB_POOL_TIMEOUT=30
# Время переоткрытия соединения с БД в секундах.
DB_POOL_RECYCLE=1800
