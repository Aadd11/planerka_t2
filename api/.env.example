# === Database ===
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/t2_schedule

# === JWT / Auth ===
# Generate a strong random value in real env
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8000,http://localhost:5173
APP_ENV=development
LOG_LEVEL=info
WEB_CONCURRENCY=2
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
